generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String?   @unique
  image         String?
  created_at    DateTime  @default(now())
  emailVerified DateTime?
  accounts      Account[]
  rooms         Room[]
  sessions      Session[]
}

model Room {
  id            String            @id @default(uuid())
  name          String
  width         Int
  height        Int
  thumbnail_url String
  user_id       String
  created_at    DateTime          @default(now())
  furnitures    PlacedFurniture[]
  user          User              @relation(fields: [user_id], references: [id])
}

model Furniture {
  id               String            @id @default(uuid())
  name             String
  model_url        String
  thumbnail_url    String
  created_at       DateTime          @default(now())
  placement_type   String
  category         String
  scale_x          Float             @default(1.0)
  scale_y          Float             @default(1.0)
  scale_z          Float             @default(1.0)
  placedFurnitures PlacedFurniture[]
}

model PlacedFurniture {
  id           String    @id @default(uuid())
  room_id      String
  furniture_id String
  position_x   Float
  position_y   Float
  position_z   Float
  rotation_y   Float
  created_at   DateTime  @default(now())
  scale_x      Float
  scale_y      Float
  scale_z      Float
  furniture    Furniture @relation(fields: [furniture_id], references: [id])
  room         Room      @relation(fields: [room_id], references: [id])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
